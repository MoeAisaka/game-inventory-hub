DATABASE_URL=postgresql://game_inventory:replace-me@db:5432/game_inventory
SESSION_COOKIE_SECURE=true
SESSION_TTL_DAYS=30
APP_VERSION=0.34.0
POSTGRES_DB=game_inventory
POSTGRES_USER=game_inventory
POSTGRES_PASSWORD=replace-with-a-long-random-password
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=3000
OPERATOR_SHARED_GID=100
BACKUP_HOST_PATH=./backups/database
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=30
CATALOG_REBUILD_HOST_PATH=./rebuild
ALLOW_CATALOG_REBUILD=false
STEAM_WEB_API_KEY=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
SYNC_CRON_SECRET=
EXTERNAL_REQUEST_TIMEOUT_MS=10000
MEDIA_STORAGE_ROOT=/data/media
MEDIA_MAX_UPLOAD_BYTES=25000000
MEDIA_HOST_PATH=./media
