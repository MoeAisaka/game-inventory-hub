{
  "name": "game-inventory-hub",
  "version": "0.34.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3100",
    "build": "DATABASE_URL=${DATABASE_URL:-postgresql://build:build@127.0.0.1:1/build} next build",
    "start": "HOSTNAME=0.0.0.0 PORT=3000 node .next/standalone/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate-database.ts",
    "db:seed": "tsx scripts/seed-admin.ts",
    "psn:test": "npm --prefix integrations/playstation-sidecar test",
    "nintendo:test": "npm --prefix integrations/nintendo-sidecar test",
    "catalog:export": "tsx scripts/export-catalog-rebuild-sources.ts",
    "catalog:plan": "tsx scripts/build-catalog-rebuild-plan.ts",
    "catalog:apply": "tsx scripts/apply-catalog-rebuild.ts",
    "metadata:backfill": "tsx scripts/backfill-game-metadata.ts",
    "genres:backfill": "tsx scripts/backfill-game-genres.ts",
    "hardware:import": "tsx scripts/import-hardware-profiles.ts",
    "status:auto-played": "tsx scripts/apply-auto-played.ts",
    "games:dedup-platform": "tsx scripts/merge-platform-game-duplicates.ts",
    "games:repair-search": "tsx scripts/apply-multilingual-search-repair.ts",
    "inventory:v2:verify": "tsx scripts/verify-inventory-v2.ts",
    "steam-family:test": "npm --prefix integrations/steam-family-sidecar test",
    "steam:workbench:verify": "tsx scripts/verify-steam-match-workbench.ts",
    "release:catalog:verify": "tsx scripts/verify-release-catalog.ts",
    "play:planner:verify": "tsx scripts/verify-play-planner.ts",
    "platform:source-home:verify": "tsx scripts/verify-platform-source-home.ts",
    "migration:dry-run": "tsx scripts/run-migration-dry-run.ts",
    "migration:rollback": "tsx scripts/rollback-migration.ts",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run psn:test && npm run nintendo:test && npm run steam-family:test && npm run build"
  },
  "dependencies": {
    "argon2": "0.44.0",
    "drizzle-orm": "0.45.2",
    "fast-xml-parser": "5.10.1",
    "fflate": "0.8.2",
    "howlongtobeat-ts": "1.2.0",
    "lucide-react": "1.24.0",
    "next": "16.2.11",
    "opencc-js": "1.4.1",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.35.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "drizzle-kit": "0.31.10",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-config-next": "16.2.10",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.18",
    "sharp": "$sharp",
    "esbuild": "$esbuild"
  }
}
